# ============ My DJ 环境变量示例 ============
# 复制本文件为 .env 后按需修改： cp .env.example .env

# ---- 服务端口 ----
BACKEND_PORT=4000
# 前端通过 nginx 对外暴露的端口（docker-compose 中映射）
WEB_PORT=8080

# ---- 音源 ----
# netease = 网易云非官方API（默认）；local = 自传音频兜底
MUSIC_SOURCE=netease
# docker-compose 已内置 netease-api 服务，无需改动
NETEASE_API_BASE=http://netease-api:3000
# 可选：网易云登录 Cookie（填了能解锁更多歌曲的播放地址，强烈建议填）
# 获取方法见 docs/DEPLOY_ALIYUN.md
NETEASE_COOKIE=

# ---- AI 主持人文案：任意 OpenAI 兼容大模型（DeepSeek / 通义千问 等）----
# 不填则自动降级为本地模板文案，App 仍可运行
# DeepSeek（默认）：
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# 若改用通义千问，则：
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_MODEL=qwen-plus
#   LLM_API_KEY=你的百炼Key

# ---- 语音合成 TTS ----
# edge = 免费微软语音(默认，无需Key)；dashscope = 阿里云CosyVoice；off = 用浏览器自带语音
TTS_PROVIDER=edge
# edge 中文音色，可选： zh-CN-XiaoxiaoNeural / zh-CN-YunxiNeural / zh-CN-XiaoyiNeural
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ---- 数据库 ----
# 默认 sqlite，零运维。文件存放在 backend/data/mydj.db
DB_FILE=./data/mydj.db

# ---- 跨域 ----
# 生产填你的域名，如 https://dj.example.com ；本地开发用 *
CORS_ORIGIN=*
